  </link>
  <!-- Joint from still_chassis_assm to wheel_assm_4 -->
  <joint name="rear_right_wheel_joint_speed" type="continuous">
    <origin xyz="-0.0804789 -0.0776141 -0.0305" rpy="-1.5708 -1.53772 3.02617e-15"/>
    <parent link="still_chassis_assm"/>
    <child link="wheel_assm_4"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="10"/>
  </joint>
  <!-- Link rplidar_a1_head -->
  <link name="rplidar_a1_head">
    <inertial>
      <origin xyz="-0.0038177 0.00287126 -0.0126469" rpy="0 0 0"/>
      <mass value="0.0241839"/>
      <inertia ixx="1.04392e-05" ixy="-1.25169e-07" ixz="2.59646e-07" iyy="9.37632e-06" iyz="-2.81087e-07" izz="1.8048e-05"/>
    </inertial>
    <!-- Part rplidar_a1_head -->
    <visual>
      <origin xyz="0.0905533 -0.132918 0.753692" rpy="3.14159 4.5115e-14 -1.06439e-17"/>
      <geometry>
        <mesh filename="package://assets/rplidar_a1_head.stl"/>
      </geometry>
      <material name="rplidar_a1_head_material">
        <color rgba="0.768627 0.886275 0.952941 1.0"/>
      </material>
    </visual>
  </link>
  <!-- Joint from still_chassis_assm to rplidar_a1_head -->
  <joint name="lidar" type="fixed">
    <origin xyz="0.0855211 0.000385868 0.1315" rpy="-3.14159 -1.87145e-13 3.07126"/>
    <parent link="still_chassis_assm"/>
    <child link="rplidar_a1_head"/>
