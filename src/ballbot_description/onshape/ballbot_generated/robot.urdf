  <joint name="imu" type="fixed">
    <origin xyz="-0.108479 0.0103859 0.005" rpy="-3.14159 -0 -3.14159"/>
    <parent link="still_chassis_assm"/>
    <child link="mpu_9250"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="10"/>
