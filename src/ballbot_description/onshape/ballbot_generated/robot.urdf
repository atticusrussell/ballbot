  <!-- Link mpu_9250 -->
  <link name="mpu_9250">
    <inertial>
      <origin xyz="0.0072258 -0.0101825 -0.00197243" rpy="0 0 0"/>
      <mass value="0.00152565"/>
      <inertia ixx="8.66938e-08" ixy="1.66001e-10" ixz="7.1086e-09" iyy="4.06315e-08" iyz="5.34551e-12" izz="1.06135e-07"/>
