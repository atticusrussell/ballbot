{
    "url": "https://cad.onshape.com/documents/833f9762904995f22ff7dd9f/w/38852c293063cfa13b203677/e/83ac8f3e1b8a64890594cf88",
    "versionID": "dbc41dc96b1adb2ff43c4047",
    "outputFormat": "urdf",
    "addDummyBaseLink": true,
    "use_scads": true,
    "merge_stls": false,
    "use_fixed_links": false,
    "collisions_as_visual": false,
    "configuration": "simplify=Default",
    "clean_config_suffix": true,
    "ignore": {
        "*screw*" : "all",
        "*lock_washer*": "all",
        "*hex_nut*": "all"
    },
    "joint_properties": {
        "lidar": {
            "type": "fixed"
        },
        "webcam": {
            "type": "fixed"
        }
    },
    "additional_xml": "gazebo.xml",
    "post_import_commands": [
        "echo 'Step 2: Fixing mesh paths and saving final URDF...'",
        "mkdir -p ../urdf",
        "python fix_ros_mesh_paths.py ballbot_generated/robot.urdf ../urdf/ballbot.urdf ballbot_description meshes",
        "echo 'Step 3: Copying meshes to final location...'",
        "mkdir -p ../meshes",
        "mkdir -p ../meshes/merged",
        "cp ballbot_generated/assets/*.stl ../meshes/",
        "cp ballbot_generated/assets/merged/*.stl ../meshes/merged/",
        "echo '--- Post-Import Processing Finished ---'"
    ]
}
